# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ── LLM Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Claude Opus 4.7 — used for debate + PM phases
GOOGLE_API_KEY=                       # Gemini 2.0 Flash — used for Phase 1 + 2 agents (free tier)

# ── Market Data ────────────────────────────────────────────────────────────────
MASSIVE_MARKET_API_KEY=               # News, analyst ratings (5 calls/min limit)
ALPHA_VANTAGE_API_KEY=                # Income statement, balance sheet, cash flow (25 req/day free)
FRED_API_KEY=                         # Macro data — rates, CPI, GDP (free, get at fred.stlouisfed.org)

# ── Social & Filings ───────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=                     # Reddit app client ID (read-only, free)
REDDIT_CLIENT_SECRET=                 # Reddit app client secret
REDDIT_USER_AGENT=hedgefund-analyser/1.0

# ── Alerts ─────────────────────────────────────────────────────────────────────
NTFY_TOPIC=your-hedge-fund-alerts     # Choose any unique topic name for ntfy.sh app

# ── Dashboard Integration (read-only) ──────────────────────────────────────────
DASHBOARD_TRADES_DB_PATH=C:\Users\user\OneDrive\Desktop\ISA Statements\Dashboard\src\trades.db

# ── Model Routing ──────────────────────────────────────────────────────────────
PHASE1_PROVIDER=gemini
PHASE1_MODEL=gemini-2.0-flash
PHASE2_PROVIDER=gemini
PHASE2_MODEL=gemini-2.0-flash
DEBATE_PROVIDER=anthropic
DEBATE_MODEL=claude-opus-4-7
PM_PROVIDER=anthropic
PM_MODEL=claude-opus-4-7
