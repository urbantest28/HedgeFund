# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ── LLM Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Market Data ────────────────────────────────────────────────────────────────
MASSIVE_MARKET_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# ── Social & Filings ───────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# SEC EDGAR requires a contact email in the User-Agent for all requests.
# https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_CONTACT=your-email@example.com

# ── Alerts ─────────────────────────────────────────────────────────────────────
NTFY_TOPIC=

# ── Dashboard Integration (read-only) ──────────────────────────────────────────
DASHBOARD_TRADES_DB_PATH=

# ── Model Routing ──────────────────────────────────────────────────────────────
PHASE1_PROVIDER=
PHASE1_MODEL=
PHASE2_PROVIDER=
PHASE2_MODEL=
DEBATE_PROVIDER=
DEBATE_MODEL=
PM_PROVIDER=
PM_MODEL=
